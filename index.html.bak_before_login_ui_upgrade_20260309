<!DOCTYPE html>

<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>שרה | Home Made Bakery</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Assistant:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --cream: #fdf6ef;
            --warm1: #f9ede0;
            --warm2: #f2d9c0;
            --copper: #c8704a;
            --copper-dark: #a85535;
            --copper-light: #e8905a;
            --brown: #2d1a0e;
            --brown-mid: #7a5040;
            --brown-light: #9a7060;
            --blush: #f5c6a8;
            --rose: #e8956d;
            --mint: #a8d5b5;
            --green: #27ae60;
            --gold: #d4a24e;
            --gold-light: #f0c97a;
            --wa: #25d366;
            --wa-dark: #128c7e;
        }
        *{margin:0;padding:0;box-sizing:border-box}
        html{scroll-behavior:smooth}
        body{font-family:'Assistant',sans-serif;background:var(--cream);color:var(--brown);overflow-x:hidden}

    /* ג”€ג”€ג”€ NAV ג”€ג”€ג”€ */
    nav{position:fixed;top:0;width:100%;z-index:200;background:rgba(253,246,239,0.97);backdrop-filter:blur(12px);display:flex;align-items:center;justify-content:space-between;padding:0 5%;height:64px;border-bottom:1px solid var(--warm2);box-shadow:0 2px 20px rgba(200,112,74,0.1);direction:rtl}
    .logo{text-decoration:none;font-family:'Playfair Display',serif;font-size:22px;font-weight:900;color:var(--brown);flex-shrink:0}
    .logo span{color:var(--copper)}
    .nav-links{display:flex;gap:6px;align-items:center}
    .nav-link{color:var(--brown-mid);text-decoration:none;font-size:13px;font-weight:700;padding:6px 12px;border-radius:20px;transition:all .2s}
    .nav-link:hover{background:var(--warm1);color:var(--copper)}
    .nav-wa{background:linear-gradient(135deg,var(--wa),var(--wa-dark));color:#fff;padding:9px 18px;border-radius:22px;font-weight:800;font-size:13px;text-decoration:none;box-shadow:0 4px 12px rgba(37,211,102,0.3);transition:transform .2s;display:flex;align-items:center;gap:6px;white-space:nowrap;flex-shrink:0}
    .nav-wa:hover{transform:scale(1.05)}

    /* ג”€ג”€ג”€ HERO ג”€ג”€ג”€ */
    .hero{min-height:100vh;background:linear-gradient(160deg,#fff8f2 0%,#fde8d0 40%,#f5d4b5 70%,#edd4b0 100%);display:flex;align-items:center;justify-content:center;padding:90px 5% 60px;text-align:center;position:relative;overflow:hidden}
    .hero::before{content:'';position:absolute;inset:0;background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23c8704a' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");pointer-events:none}
    .hero-floats{position:absolute;inset:0;pointer-events:none;overflow:hidden}
    .hf{position:absolute;border-radius:50%;opacity:0.12;animation:float 8s ease-in-out infinite}
    .hf1{width:300px;height:300px;background:radial-gradient(circle,var(--copper),transparent);top:-80px;left:-80px;animation-delay:0s}
    .hf2{width:200px;height:200px;background:radial-gradient(circle,var(--gold),transparent);bottom:20%;right:-60px;animation-delay:-3s}
    .hf3{width:150px;height:150px;background:radial-gradient(circle,var(--rose),transparent);top:30%;left:10%;animation-delay:-5s}
    @keyframes float{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-20px) scale(1.05)}}
    .hero-inner{position:relative;z-index:2}
    .hero-badge{display:inline-flex;align-items:center;gap:7px;background:rgba(200,112,74,0.12);border:1.5px solid rgba(200,112,74,0.25);color:var(--copper-dark);padding:7px 18px;border-radius:20px;font-size:11px;letter-spacing:2.5px;font-weight:800;margin-bottom:24px;text-transform:uppercase}
    .hero h1{font-family:'Playfair Display',serif;font-size:clamp(48px,9vw,88px);font-weight:900;line-height:1;margin-bottom:18px;color:var(--brown)}
    .hero h1 .accent{color:var(--copper);display:block}
    .hero-desc{color:var(--brown-mid);font-size:16px;line-height:1.9;margin-bottom:34px;max-width:480px;margin-inline:auto;font-weight:600}
    .hero-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
    .btn-primary{background:linear-gradient(135deg,var(--copper),var(--copper-dark));color:#fff;padding:15px 34px;border-radius:30px;font-weight:800;font-size:15px;border:none;cursor:pointer;box-shadow:0 8px 24px rgba(200,112,74,0.35);transition:all .3s;font-family:'Assistant',sans-serif}
    .btn-primary:hover{transform:translateY(-3px);box-shadow:0 14px 30px rgba(200,112,74,0.45)}
    .btn-wa-hero{background:linear-gradient(135deg,var(--wa),var(--wa-dark));color:#fff;padding:15px 34px;border-radius:30px;font-weight:800;font-size:15px;text-decoration:none;box-shadow:0 8px 24px rgba(37,211,102,0.3);transition:all .3s;display:inline-block}
    .btn-wa-hero:hover{transform:translateY(-3px)}
    .hero-scroll{margin-top:40px;color:var(--brown-light);font-size:12px;letter-spacing:2px;text-transform:uppercase;font-weight:700;animation:bounce 2s infinite}
    @keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(6px)}}

    /* ג”€ג”€ג”€ TRUST BAR ג”€ג”€ג”€ */
    .trust{background:linear-gradient(135deg,var(--brown) 0%,#4a2510 100%);padding:16px 5%;display:flex;justify-content:center;gap:0;flex-wrap:wrap}
    .trust-item{display:flex;align-items:center;gap:8px;color:rgba(255,255,255,0.9);font-size:13px;font-weight:700;padding:6px 20px;border-left:1px solid rgba(255,255,255,0.15)}
    .trust-item:last-child{border-left:none}
    .trust-item:first-child{border-left:none}

    /* ג”€ג”€ג”€ SECTION SHARED ג”€ג”€ג”€ */
    .section-header{text-align:center;margin-bottom:50px}
    .sec-tag{color:var(--copper);font-size:11px;letter-spacing:3.5px;font-weight:800;text-transform:uppercase;margin-bottom:10px;display:block}
    .section-header h2{font-family:'Playfair Display',serif;font-size:clamp(26px,4vw,42px);font-weight:900;color:var(--brown)}
    .section-header p{color:var(--brown-light);font-size:14px;margin-top:10px;font-weight:600}

    /* ג”€ג”€ג”€ CATALOG ג”€ג”€ג”€ */
    .catalog{padding:90px 5%;background:var(--cream);position:relative}
    .catalog::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--copper),var(--gold),var(--copper-light),var(--copper))}

    .cat-tabs{display:flex;justify-content:center;gap:10px;flex-wrap:wrap;margin-bottom:44px}
    .cat-tab{background:#fff;border:2px solid var(--warm2);color:var(--brown-mid);padding:10px 22px;border-radius:24px;font-size:13px;font-weight:800;cursor:pointer;transition:all .3s;font-family:'Assistant',sans-serif;box-shadow:0 2px 8px rgba(0,0,0,0.04)}
    .cat-tab.active,.cat-tab:hover{background:linear-gradient(135deg,var(--copper),var(--copper-dark));color:#fff;border-color:transparent;box-shadow:0 6px 18px rgba(200,112,74,0.3)}

    .prod-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:24px;max-width:1160px;margin:0 auto}
    .prod-card{background:#fff;border-radius:22px;overflow:hidden;box-shadow:0 4px 18px rgba(0,0,0,0.07);transition:all .35s;border:2px solid transparent;cursor:pointer}
    .prod-card:hover{transform:translateY(-8px);box-shadow:0 18px 40px rgba(200,112,74,0.14);border-color:var(--blush)}
    .prod-img{height:210px;overflow:hidden;position:relative;background:var(--warm1)}
    .prod-img img{width:100%;height:100%;object-fit:cover;transition:transform .5s;display:block}
    .prod-card:hover .prod-img img{transform:scale(1.07)}
    .prod-ribbon{position:absolute;top:12px;right:12px;padding:5px 13px;border-radius:14px;font-size:11px;font-weight:800;z-index:2;letter-spacing:.5px}
    .rb-best{background:linear-gradient(135deg,var(--copper),var(--copper-dark));color:#fff}
    .rb-bday{background:linear-gradient(135deg,#e91e8c,#c2185b);color:#fff}
    .rb-love{background:linear-gradient(135deg,#e74c3c,#c0392b);color:#fff}
    .rb-num{background:linear-gradient(135deg,#9b59b6,#7d3c98);color:#fff}
    .rb-tray{background:linear-gradient(135deg,var(--green),#1e8449);color:#fff}
    .rb-custom{background:linear-gradient(135deg,var(--gold),#b8860b);color:#fff}
    .prod-body{padding:20px;background:linear-gradient(160deg,#fff8f2,#fdeee0)}
    .prod-name{font-family:'Playfair Display',serif;font-size:17px;font-weight:700;color:var(--brown);margin-bottom:7px}
    .prod-desc{color:var(--brown-mid);font-size:13px;line-height:1.6;margin-bottom:16px;font-weight:600}
    .prod-btn{width:100%;background:linear-gradient(135deg,var(--copper),var(--copper-dark));color:#fff;border:none;padding:12px;border-radius:14px;font-size:14px;font-weight:800;cursor:pointer;font-family:'Assistant',sans-serif;transition:opacity .2s;pointer-events:none}
    .prod-card:hover .prod-btn{opacity:.9}

    /* ג”€ג”€ג”€ REVIEWS ג”€ג”€ג”€ */
    .reviews{background:linear-gradient(160deg,#fff9f4,var(--warm1));padding:90px 5%;position:relative}
    .reviews-layout{max-width:1020px;margin:0 auto;display:grid;grid-template-columns:280px 1fr;gap:50px;align-items:start}
    .reviews-summary{background:linear-gradient(145deg,var(--brown),#4a2510);border-radius:26px;padding:36px 28px;text-align:center;position:sticky;top:80px;color:#fff}
    .rs-score{font-family:'Playfair Display',serif;font-size:76px;font-weight:900;color:#fff;line-height:1}
    .rs-stars{color:var(--gold-light);font-size:26px;margin:10px 0;letter-spacing:3px}
    .rs-count{color:rgba(255,255,255,0.65);font-size:13px;margin-bottom:26px;font-weight:600}
    .rs-bars{text-align:right}
    .rs-bar-row{display:flex;align-items:center;gap:10px;margin-bottom:10px}
    .rs-bar-label{font-size:13px;color:rgba(255,255,255,0.8);font-weight:700;white-space:nowrap;min-width:48px}
    .rs-bar-track{flex:1;background:rgba(255,255,255,0.15);border-radius:6px;height:8px;overflow:hidden}
    .rs-bar-fill{height:100%;border-radius:6px;background:linear-gradient(90deg,var(--gold-light),var(--copper-light))}
    .rs-bar-num{font-size:12px;color:rgba(255,255,255,0.5);min-width:18px}
    .reviews-list{display:flex;flex-direction:column;gap:16px}
    .review-card{background:#fff;border:1.5px solid var(--warm2);border-radius:18px;padding:22px;transition:all .3s;box-shadow:0 3px 12px rgba(0,0,0,0.04)}
    .review-card:hover{border-color:var(--copper);box-shadow:0 8px 24px rgba(200,112,74,0.1)}
    .rc-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
    .rc-author{display:flex;align-items:center;gap:10px}
    .rc-av{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--copper),var(--copper-dark));display:flex;align-items:center;justify-content:center;color:#fff;font-weight:900;font-size:15px;flex-shrink:0}
    .rc-name{font-weight:800;font-size:15px;color:var(--brown)}
    .rc-loc{color:#bbb;font-size:11px;font-weight:600}
    .rc-stars{color:var(--gold);font-size:15px;letter-spacing:1px}
    .rc-text{color:#5a3a28;font-size:14px;line-height:1.8;font-style:italic;font-weight:600}
    .review-media{display:grid;grid-template-columns:repeat(auto-fill,minmax(80px,1fr));gap:8px;margin-top:12px}
    .review-media img{width:100%;height:80px;object-fit:cover;border-radius:10px;border:1px solid var(--warm2)}
    .review-add-wrap{max-width:1020px;margin:28px auto 0}
    .review-add-card{background:#fff;border:1.5px solid var(--warm2);border-radius:18px;padding:20px;box-shadow:0 3px 12px rgba(0,0,0,0.04)}
    .review-add-card h3{font-family:'Playfair Display',serif;font-size:22px;color:var(--brown);margin-bottom:8px}
    .review-add-card p{color:var(--brown-mid);font-size:14px;line-height:1.6;margin-bottom:12px}
    .review-form-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:10px}
    .review-input{width:100%;border:2px solid var(--warm2);border-radius:12px;padding:10px 12px;font-family:'Assistant',sans-serif;font-size:14px}
    .review-input:focus{outline:none;border-color:var(--copper)}
    .review-textarea{width:100%;border:2px solid var(--warm2);border-radius:12px;padding:10px 12px;min-height:90px;resize:vertical;font-family:'Assistant',sans-serif;font-size:14px}
    .review-upload-row{display:flex;align-items:center;gap:10px;margin:10px 0}
    .review-upload-label{font-size:13px;color:var(--brown-mid);font-weight:700}
    .review-images-preview{display:grid;grid-template-columns:repeat(auto-fill,minmax(72px,1fr));gap:8px;margin:8px 0 12px}
    .review-images-preview img{width:100%;height:72px;object-fit:cover;border-radius:10px;border:1px solid var(--warm2)}
    .review-submit-btn{padding:12px 22px;font-size:14px}
    .review-inline-msg{font-size:12px;color:var(--brown-light);margin-top:8px}

    /* ג”€ג”€ג”€ INFO ג”€ג”€ג”€ */
    .info-section{background:linear-gradient(135deg,var(--brown) 0%,#3d1f10 50%,#5a2d16 100%);padding:80px 5%;position:relative;overflow:hidden}
    .info-section::before{content:'';position:absolute;inset:0;background:url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M20 20c0-5.5-4.5-10-10-10S0 14.5 0 20s4.5 10 10 10 10-4.5 10-10zm10 0c0-5.5 4.5-10 10-10s0 14.5 0 20-4.5 10-10 10-10-4.5-10-10z'/%3E%3C/g%3E%3C/svg%3E");pointer-events:none}
    .info-section .section-header{position:relative;z-index:1}
    .info-section .sec-tag{color:var(--gold-light)}
    .info-section .section-header h2{color:#fff}
    .info-grid{max-width:900px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:18px;position:relative;z-index:1}
    .info-card{background:rgba(255,255,255,0.08);backdrop-filter:blur(4px);border:1.5px solid rgba(255,255,255,0.12);border-radius:20px;padding:28px 20px;text-align:center;transition:all .3s}
    .info-card:hover{background:rgba(255,255,255,0.13);border-color:rgba(200,112,74,0.5);transform:translateY(-4px)}
    .info-icon{font-size:38px;margin-bottom:14px;display:block}
    .info-title{font-family:'Playfair Display',serif;font-size:15px;font-weight:700;color:#fff;margin-bottom:10px}
    .info-text{color:rgba(255,255,255,0.7);font-size:13px;line-height:1.75;font-weight:600}
    .info-text strong{color:var(--gold-light)}

    /* ג”€ג”€ג”€ KOSHER BADGE ג”€ג”€ג”€ */
    .kosher-badge{display:inline-flex;align-items:center;gap:8px;background:linear-gradient(135deg,var(--gold),#c8860a);color:#fff;padding:8px 20px;border-radius:20px;font-size:12px;font-weight:800;letter-spacing:1px;margin-top:12px;box-shadow:0 4px 14px rgba(212,162,78,0.4)}

    /* ג”€ג”€ג”€ CTA ג”€ג”€ג”€ */
    .cta{background:linear-gradient(135deg,#3d1f10,#5a2d16);color:#fff;padding:80px 5%;text-align:center;position:relative;overflow:hidden}
    .cta::before{content:'ג¦';position:absolute;font-size:300px;opacity:.03;top:-60px;left:-40px;pointer-events:none}
    .cta h2{font-family:'Playfair Display',serif;font-size:clamp(24px,4vw,42px);font-weight:900;margin-bottom:14px;position:relative}
    .cta h2 span{color:var(--gold-light)}
    .cta p{font-size:15px;opacity:.8;margin-bottom:32px;max-width:440px;margin-inline:auto;line-height:1.8;font-weight:600;position:relative}
    .btn-wa-big{display:inline-flex;align-items:center;gap:10px;background:linear-gradient(135deg,var(--wa),var(--wa-dark));color:#fff;padding:16px 38px;border-radius:32px;font-weight:800;font-size:16px;text-decoration:none;box-shadow:0 10px 28px rgba(37,211,102,0.35);transition:all .3s;position:relative}
    .btn-wa-big:hover{transform:translateY(-3px);box-shadow:0 16px 36px rgba(37,211,102,0.45)}

    /* ג”€ג”€ג”€ FOOTER ג”€ג”€ג”€ */
    footer{background:#1a0e06;padding:40px 5% 24px;color:rgba(255,255,255,.5);text-align:center}
    .footer-brand{font-family:'Playfair Display',serif;font-size:20px;font-weight:900;color:#fff;margin-bottom:12px}
    .footer-brand span{color:var(--copper-light)}
    .footer-links{display:flex;justify-content:center;gap:24px;flex-wrap:wrap;margin-bottom:22px}
    .footer-links a{color:rgba(255,255,255,.55);text-decoration:none;font-size:13px;font-weight:600;transition:color .2s}
    .footer-links a:hover{color:var(--copper-light)}
    .footer-bottom{border-top:1px solid rgba(255,255,255,.08);padding-top:18px;font-size:12px;font-weight:600}

    /* ג”€ג”€ג”€ MODAL ג”€ג”€ג”€ */
    .modal-overlay{display:none;position:fixed;inset:0;background:rgba(20,10,5,0.65);z-index:500;align-items:center;justify-content:center;padding:16px;backdrop-filter:blur(4px)}
    .modal-overlay.open{display:flex}
    .modal{background:#fff;border-radius:26px;max-width:460px;width:100%;position:relative;max-height:92vh;overflow-y:auto;box-shadow:0 30px 80px rgba(0,0,0,0.3)}
    .modal-img{width:100%;height:210px;object-fit:cover;border-radius:26px 26px 0 0;display:block}
    .modal-body{padding:26px}
    .modal-close{position:absolute;top:14px;left:14px;background:rgba(0,0,0,0.45);border:none;width:32px;height:32px;border-radius:50%;font-size:14px;cursor:pointer;color:#fff;z-index:10;transition:background .2s}
    .modal-close:hover{background:rgba(0,0,0,0.7)}
    .modal-prod-name{font-family:'Playfair Display',serif;font-size:20px;font-weight:900;color:var(--brown);margin-bottom:6px}
    .modal-prod-desc{color:var(--brown-light);font-size:13px;margin-bottom:18px;line-height:1.65;font-weight:600}
    .modal-info{background:var(--warm1);border-radius:14px;padding:13px 15px;margin-bottom:18px;font-size:13px;color:var(--brown-mid);line-height:1.7;border:1.5px solid var(--warm2);font-weight:600}
    .modal h4{font-size:13px;font-weight:800;color:var(--brown);margin-bottom:10px;letter-spacing:.5px}
    .modal-pay{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:16px}
    .pay-opt{border:2px solid var(--warm2);border-radius:14px;padding:11px 6px;text-align:center;cursor:pointer;transition:all .25s;font-size:13px;color:var(--brown-mid);font-weight:700;font-family:'Assistant',sans-serif}
    .pay-opt.selected{border-color:var(--copper);background:#fff8f3;color:var(--copper)}
    .pay-icon{font-size:22px;display:block;margin-bottom:5px}
    .modal-input{width:100%;border:2px solid var(--warm2);border-radius:14px;padding:12px 16px;font-size:15px;font-family:'Assistant',sans-serif;color:var(--brown);outline:none;transition:border .25s;margin-bottom:12px;direction:rtl;font-weight:600;background:#fff}
    .modal-input:focus{border-color:var(--copper)}
    .modal-submit{width:100%;background:linear-gradient(135deg,var(--wa),var(--wa-dark));color:#fff;border:none;padding:15px;border-radius:16px;font-size:15px;font-weight:800;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;font-family:'Assistant',sans-serif;transition:opacity .2s;box-shadow:0 6px 18px rgba(37,211,102,0.3)}
    .modal-submit:hover{opacity:.93}
    .modal-success{text-align:center;padding:34px 20px;display:none}
    .success-icon{font-size:62px;margin-bottom:14px}
    .success-title{font-family:'Playfair Display',serif;font-size:22px;font-weight:900;color:var(--brown);margin-bottom:10px}
    .success-text{color:var(--brown-mid);font-size:14px;line-height:1.75;font-weight:600}

    /* custom textarea */
    .custom-note-area{background:linear-gradient(135deg,#fff8f0,#fdf0e5);border:2px solid var(--warm2);border-radius:16px;padding:16px;margin-bottom:14px}
    .custom-note-area h4{margin-bottom:10px;color:var(--copper-dark)}
    .custom-note-area .modal-input{margin-bottom:0;background:rgba(255,255,255,0.8)}

    /* custom fields box */
    .custom-fields-box{background:linear-gradient(135deg,#fff5e8,#ffecd6);border:2px dashed var(--copper-light);border-radius:18px;padding:18px;margin-bottom:14px}
