        '<strong>' + escapeHtml(gift.emoji) + ' ' + level + '</strong>' +
        '<div class=\"pc-sub\">' + escapeHtml(gift.name) + '</div>' +
      '</div>';
    }).join('');

    var nextText = points >= maxShown
      ? 'פתחתם כבר את 300/600/900. ממשיכים לצבור ל-' + nextLevel + ' נק׳'
      : 'עד המתנה הבאה: ' + missing + ' נק׳';

    el.innerHTML =
      '<div class=\"points-head\"><div class=\"points-title\">מד מתנות</div><div class=\"points-total\">' + points + ' נק׳</div></div>' +
      '<div class=\"points-meter\"><div class=\"points-line\"><div class=\"points-line-fill\" style=\"width:' + meterPct + '%\"></div></div><div class=\"points-marks\">' + marksHtml + '</div></div>' +
      '<div class=\"points-labels\">' + chipsHtml + '</div>' +
      '<div class=\"points-next\">' + nextText + '</div>';
  }

