        '<button type="button" onclick="selectReward(' + level + ')" style="background:' + (picked ? '#27ae60' : '#c8704a') + '">' + (picked ? 'נבחר' : 'ממש') + '</button>' +
      '</div>';
    });

    wrap.innerHTML = html;
  }

  function escapeHtml(v){
    return String(v || '').replace(/[&<>"]|'/g, function(ch){
      var map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', '\'': '&#39;' };
      return map[ch] || ch;
    });
  }

  function starsByRate(rate){
    var r = Math.max(1, Math.min(5, Number(rate || 5)));
    return '★★★★★'.slice(0, r) + '☆☆☆☆☆'.slice(0, 5 - r);
  }

  function formatReviewDate(ts){
    if(!ts) return '';
    try {
      if(ts.seconds){ return new Date(ts.seconds * 1000).toLocaleDateString('he-IL'); }
      return new Date(ts).toLocaleDateString('he-IL');
    } catch(e){
      return '';
    }
  }

  function renderUserReviewCard(r){
    var name = escapeHtml(r.name || 'לקוחה');
    var city = escapeHtml(r.city || 'לא צוין');
    var text = escapeHtml(r.text || '');
    var stars = starsByRate(r.rating || 5);
    var initial = name ? name.charAt(0) : 'ל';
    var dateTxt = formatReviewDate(r.createdAt);
    var media = '';

    if(Array.isArray(r.images) && r.images.length){
      media = '<div class="review-media">';
      r.images.forEach(function(url){
        media += '<img src="' + escapeHtml(url) + '" alt="תמונת ביקורת" loading="lazy">';
      });
      media += '</div>';
    }

    return '<div class="review-card">' +
      '<div class="rc-top"><div class="rc-author"><div class="rc-av">' + escapeHtml(initial) + '</div><div><div class="rc-name">' + name + '</div><div class="rc-loc">' + city + (dateTxt ? ' · ' + escapeHtml(dateTxt) : '') + '</div></div></div><div class="rc-stars">' + stars + '</div></div>' +
      '<div class="rc-text">"' + text + '"</div>' +
      media +
    '</div>';
  }

  function renderUserReviews(){
    var wrap = document.getElementById('reviewsUserList');
    if(!wrap) return;

    if(!userReviews || userReviews.length === 0){
      wrap.innerHTML = '';
      return;
    }

    var html = '<div style="font-weight:800;margin:0 0 10px">ביקורות חדשות מהאתר</div>';
    userReviews.forEach(function(r){
      html += renderUserReviewCard(r);
    });
    wrap.innerHTML = html;
  }

  function setReviewAuthState(){
    var hint = document.getElementById('reviewAuthHint');
    var form = document.getElementById('reviewFormCard');
    if(!hint || !form) return;

    if(currentUser){
      hint.style.display = 'none';
      form.style.display = 'block';
      var nameEl = document.getElementById('reviewName');
      if(nameEl && !nameEl.value){
        var fallback = (currentUser.email || '').split('@')[0] || '';
        nameEl.value = fallback;
      }
    } else {
      hint.style.display = 'block';
      form.style.display = 'none';
    }
  }

  window.previewReviewImages = function(){
    var input = document.getElementById('reviewImages');
    var preview = document.getElementById('reviewImagesPreview');
    if(!input || !preview) return;

    var files = Array.from(input.files || []).slice(0, 3);
    if((input.files || []).length > 3){
      toast('אפשר להעלות עד 3 תמונות לביקורת');
    }

    var html = '';
    files.forEach(function(file){
      if(file && file.type && file.type.indexOf('image/') === 0){
        var url = URL.createObjectURL(file);
        html += '<img src="' + url + '" alt="תצוגה מקדימה">';
      }
    });
    preview.innerHTML = html;
  };

  async function uploadReviewImages(files){
    if(!fb || !fb.storage || !fb.storageRef || !fb.uploadBytes || !fb.getDownloadURL) return [];
    var urls = [];
    var maxSize = 4 * 1024 * 1024;

    for(var i=0; i<files.length && i<3; i++){
      var file = files[i];
      if(!file || !file.type || file.type.indexOf('image/') !== 0) continue;
      if(file.size > maxSize){
        toast('תמונה גדולה מדי. אפשר עד 4MB לתמונה.');
        continue;
      }

      var safeName = (file.name || ('img_' + i)).replace(/[^a-zA-Z0-9._-]+/g, '_');
      var fileRef = fb.storageRef(fb.storage, 'reviews/' + (currentUser ? currentUser.uid : 'guest') + '/' + Date.now() + '_' + i + '_' + safeName);
      await fb.uploadBytes(fileRef, file);
      var downloadUrl = await fb.getDownloadURL(fileRef);
      urls.push(downloadUrl);
    }

    return urls;
  }

  async function loadUserReviews(){
    var wrap = document.getElementById('reviewsUserList');
    if(!wrap || !fb) return;

    try {
      var q = fb.query(fb.collection(fb.db, 'reviews'), fb.orderBy('createdAt', 'desc'));
      var snap = await fb.getDocs(q);
      userReviews = [];
      snap.forEach(function(docSnap){
        var d = docSnap.data() || {};
        userReviews.push({
          id: docSnap.id,
          name: d.name || '',
          city: d.city || '',
          rating: Number(d.rating || 5),
          text: d.text || '',
          images: Array.isArray(d.images) ? d.images : [],
          createdAt: d.createdAt || null
        });
      });
      renderUserReviews();
    } catch(err){
      wrap.innerHTML = '<div class="review-inline-msg">לא הצלחנו לטעון ביקורות חדשות כרגע.</div>';
    }
  }

  window.submitReview = async function(){
    if(!currentUser){
      toast('צריך להתחבר כדי להוסיף ביקורת');
      openAuthModal();
      return;
    }
    if(!fb){
      toast('Firebase לא מוכן כרגע');
      return;
    }

    var nameEl = document.getElementById('reviewName');
    var cityEl = document.getElementById('reviewCity');
    var ratingEl = document.getElementById('reviewRating');
    var textEl = document.getElementById('reviewText');
    var imagesEl = document.getElementById('reviewImages');
    var submitBtn = document.getElementById('reviewSubmitBtn');
    var preview = document.getElementById('reviewImagesPreview');

    var name = (nameEl && nameEl.value ? nameEl.value : '').trim();
    var city = (cityEl && cityEl.value ? cityEl.value : '').trim();
    var rating = Number(ratingEl && ratingEl.value ? ratingEl.value : 5);
    var text = (textEl && textEl.value ? textEl.value : '').trim();
    var files = Array.from(imagesEl && imagesEl.files ? imagesEl.files : []).slice(0, 3);

    if(!name){ toast('חסר שם לביקורת'); return; }
    if(text.length < 8){ toast('כתבו ביקורת של לפחות 8 תווים'); return; }

    if(submitBtn){
      submitBtn.disabled = true;
      submitBtn.style.opacity = '0.75';
      submitBtn.textContent = 'מפרסם ביקורת...';
    }

    try {
      var imageUrls = await uploadReviewImages(files);
      await fb.addDoc(fb.collection(fb.db, 'reviews'), {
        userId: currentUser.uid,
        userEmail: currentUser.email || '',
        name: name,
        city: city,
        rating: rating,
        text: text,
        images: imageUrls,
        createdAt: fb.serverTimestamp()
      });

      if(textEl) textEl.value = '';
      if(imagesEl) imagesEl.value = '';
      if(preview) preview.innerHTML = '';
      toast('הביקורת פורסמה בהצלחה, תודה!');
      await loadUserReviews();
    } catch(err){
      toast('שגיאה בפרסום הביקורת. נסו שוב.');
    } finally {
      if(submitBtn){
        submitBtn.disabled = false;
        submitBtn.style.opacity = '1';
        submitBtn.textContent = 'פרסום ביקורת';
      }
    }
  };


  function getCartSubtotal(){
    return cartItems.reduce(function(sum, item){ return sum + Number(item.price || 0); }, 0);
  }

  function getDeliveryCityLabel(code){
    if(code === 'harish') return 'חריש';
    if(code === 'tal_menashe') return 'טל מנשה';
    if(code === 'pardes_hanna') return 'פרדס חנה';
    return '';
  }

  function calcDelivery(subtotal){
    var modeEl = document.getElementById('checkoutDeliveryMode');
    var cityEl = document.getElementById('checkoutDeliveryCity');
    var mode = modeEl ? (modeEl.value || 'pickup') : 'pickup';
    var city = cityEl ? (cityEl.value || '') : '';
    var cityLabel = getDeliveryCityLabel(city);
    var fee = 0;
    var note = 'איסוף עצמי (חינם)';

    if(mode === 'delivery'){
      if(city === 'harish'){
        fee = Number(subtotal || 0) >= 150 ? 0 : 10;
        note = fee === 0 ? 'משלוח לחריש חינם (מעל ₪150)' : 'משלוח לחריש ₪10';
      } else if(city === 'tal_menashe' || city === 'pardes_hanna'){
        fee = 70;
        note = 'משלוח ל' + cityLabel + ' ₪70';
      } else {
        fee = 0;
        note = 'בחרו יעד משלוח';
      }
    }

    return { mode: mode, city: city, cityLabel: cityLabel, fee: fee, note: note };
  }

  window.updateCheckoutTotals = function(){
    ensureUI();
    var modeEl = document.getElementById('checkoutDeliveryMode');
    var cityEl = document.getElementById('checkoutDeliveryCity');
    var addressEl = document.getElementById('checkoutAddress');
    var infoEl = document.getElementById('checkoutTotalsInfo');
    var totalInput = document.getElementById('checkoutTotal');
    if(!modeEl || !cityEl || !addressEl || !infoEl) return;

    var subtotal = getCartSubtotal();
    var isDelivery = modeEl.value === 'delivery';

    cityEl.style.display = isDelivery ? 'block' : 'none';
    addressEl.style.display = isDelivery ? 'block' : 'none';

    if(!isDelivery){
      cityEl.value = '';
      addressEl.value = '';
    }

    var delivery = calcDelivery(subtotal);
    var autoTotal = subtotal + Number(delivery.fee || 0);
    var deliveryLabel = isDelivery ? delivery.note : 'איסוף עצמי (חינם)';
    var pickupText = !isDelivery ? ('<br>כתובת איסוף: ' + PICKUP_ADDRESS) : '';

    infoEl.innerHTML = 'סכום מוצרים: ' + shekel(subtotal) + '<br>' +
      'משלוח/איסוף: ' + deliveryLabel + pickupText + '<br><strong>סה"כ לתשלום: ' + shekel(autoTotal) + '</strong>';

    if(totalInput && !manualTotalTouched){
      totalInput.value = autoTotal > 0 ? String(autoTotal) : '';
    }
  };

  function renderCart(){
    ensureUI();
    var list = document.getElementById('cartList');
    var badge = document.getElementById('cartBadge');
    if(!list || !badge) return;

    badge.textContent = String(cartItems.length);

    if(cartItems.length === 0){
      list.innerHTML = '<div style="font-size:13px;color:#7a5040">הסל ריק כרגע.</div>';
      var t0 = document.getElementById('checkoutTotal');
      if(t0 && !manualTotalTouched) t0.value = '';
      updateCheckoutTotals();
      return;
    }

    var subtotal = getCartSubtotal();
    var html = '';

    cartItems.forEach(function(item){
      html += '<div class="cart-item">' +
        '<div class="cart-item-top"><strong>' + item.name + '</strong><button class="cart-remove" type="button" onclick="removeCartItem(\'' + item.id + '\')">הסר</button></div>' +
        '<div style="font-size:12px;color:#7a5040;margin-top:4px">' + (item.details || '') + '</div>' +
        '<div style="font-size:12px;color:#2d1a0e;margin-top:6px;font-weight:800">' + (item.price > 0 ? ('מחיר: ' + shekel(item.price)) : 'מחיר יעודכן') + '</div>' +
      '</div>';
    });

    html += '<div style="margin-top:8px;font-size:13px;font-weight:800">סה״כ מחושב: ' + shekel(subtotal) + '</div>';
    list.innerHTML = html;
    updateCheckoutTotals();
  }

  async function loadProfile(){
    if(!fb || !currentUser) return;
    var ref = fb.doc(fb.db, 'users', currentUser.uid);
    var snap = await fb.getDoc(ref);

    if(!snap.exists()){
      await fb.setDoc(ref, {
        email: currentUser.email || '',
        points: 0,
        redeemedRewards: [],
        createdAt: fb.serverTimestamp(),
        updatedAt: fb.serverTimestamp()
      });
      profile = { points: 0, redeemedRewards: [] };
    } else {
      var d = snap.data() || {};
      profile = {
        points: Number(d.points || 0),
        redeemedRewards: Array.isArray(d.redeemedRewards) ? d.redeemedRewards : []
      };
    }

    renderPoints();
    renderRewards();
  }

  async function authReady(){
    if(!window.firebaseCtx) return;
    fb = window.firebaseCtx;
    ensureUI();

    fb.onAuthStateChanged(fb.auth, async function(user){
      currentUser = user || null;
      selectedRewardLevel = null;
      manualTotalTouched = false;

      if(currentUser){
        loadCart();
        setAuthUI();
        renderCart();
        renderPoints();
        renderRewards();
        loadProfile().catch(function(){});
      } else {
        cartItems = [];
        profile = { points: 0, redeemedRewards: [] };
        setAuthUI();
        renderCart();
        renderPoints();
        renderRewards();
      }

      setReviewAuthState();
      loadUserReviews().catch(function(){});
    });
  }

  window.openAuthModal = function(){
    ensureUI();
    document.getElementById('authModal').classList.add('open');
  };

  window.closeAuthModal = function(e){
    if(!e || e.target.id === 'authModal'){
      document.getElementById('authModal').classList.remove('open');
    }
  };

  window.loginUser = async function(){
    if(!fb) return;
    var email = (document.getElementById('authEmail').value || '').trim();
    var pass = (document.getElementById('authPass').value || '').trim();
    if(!email || !pass){ toast('חסר אימייל או סיסמה'); return; }
    setAuthPending(true, 'מתחבר...');
    try {
      await fb.signInWithEmailAndPassword(fb.auth, email, pass);
      toast('התחברת בהצלחה');
      closeAuthModal();
    } catch(err){
      toast('שגיאת התחברות: ' + (err && err.code ? err.code : 'error'));
    } finally {
      setAuthPending(false);
    }
  };

  window.registerUser = async function(){
    if(!fb) return;
    var email = (document.getElementById('authEmail').value || '').trim();
    var pass = (document.getElementById('authPass').value || '').trim();
    if(!email || !pass){ toast('חסר אימייל או סיסמה'); return; }
    setAuthPending(true, 'נרשם...');
    try {
      var cred = await fb.createUserWithEmailAndPassword(fb.auth, email, pass);
      if(cred && cred.user){
        await fb.setDoc(fb.doc(fb.db, 'users', cred.user.uid), {
          email: email,
          points: 0,
          redeemedRewards: [],
          createdAt: fb.serverTimestamp(),
          updatedAt: fb.serverTimestamp()
        }, { merge: true });
      }
      toast('נרשמת בהצלחה');
      closeAuthModal();
    } catch(err){
      toast('שגיאת הרשמה: ' + (err && err.code ? err.code : 'error'));
    } finally {
      setAuthPending(false);
    }
  };

  window.logoutUser = async function(){
    if(!fb) return;
    await fb.signOut(fb.auth);
    toast('התנתקת');
  };

  window.toggleCart = function(open){
    ensureUI();
    var el = document.getElementById('cartDrawer');
    if(!el) return;
    if(open){ el.classList.add('open'); }
    else { el.classList.remove('open'); }
  };

  window.removeCartItem = function(id){
    cartItems = cartItems.filter(function(item){ return item.id !== id; });
    saveCart();
    renderCart();
  };

  window.markManualTotal = function(){
    manualTotalTouched = true;
  };

  window.selectReward = function(level){
    selectedRewardLevel = (selectedRewardLevel === level) ? null : level;
    renderRewards();
  };

  window.sendCartOrder = async function(){
    if(!currentUser){
      toast('צריך להתחבר כדי לשלוח הזמנה ולקבל מתנות');
      openAuthModal();
      return;
    }

    if(cartItems.length === 0 && !selectedRewardLevel){
      toast('הסל ריק');
      return;
    }

    updateCheckoutTotals();

    var name = (document.getElementById('checkoutName').value || '').trim();
    var phone = (document.getElementById('checkoutPhone').value || '').trim();
    var payment = (document.getElementById('checkoutPayment').value || '').trim();
    var deliveryMode = (document.getElementById('checkoutDeliveryMode').value || 'pickup').trim();
    var deliveryCity = (document.getElementById('checkoutDeliveryCity').value || '').trim();
    var addressInput = (document.getElementById('checkoutAddress').value || '').trim();
    var readyBy = (document.getElementById('checkoutReadyBy').value || '').trim();
    var note = (document.getElementById('checkoutNote').value || '').trim();
    var totalInput = document.getElementById('checkoutTotal');
    var orderTotal = Number(totalInput ? (totalInput.value || 0) : 0);

    if(!name || !phone || !payment){
      toast('חסר שם / טלפון / תשלום');
      return;
    }

    var subtotal = getCartSubtotal();
    var delivery = calcDelivery(subtotal);

    if(deliveryMode === 'delivery' && !deliveryCity){
      toast('צריך לבחור יעד משלוח');
      return;
    }

    if(deliveryMode === 'delivery' && !addressInput){
      toast('חסרה כתובת למשלוח');
      return;
    }

    var shippingFee = Number(delivery.fee || 0);
    var autoOrderTotal = subtotal + shippingFee;

    if(orderTotal <= 0){
      orderTotal = autoOrderTotal;
      if(totalInput && !manualTotalTouched){
        totalInput.value = orderTotal > 0 ? String(orderTotal) : '';
      }
    }

    if(cartItems.length > 0 && orderTotal <= 0){
      toast('צריך להזין סכום הזמנה בש״ח');
      return;
    }

    var pointsToAdd = Math.floor(orderTotal);
    var reward = selectedRewardLevel ? getGiftForLevel(selectedRewardLevel) : null;
    var orderNum = 'S' + Date.now().toString().slice(-6);
    var deliveryLabel = deliveryMode === 'delivery'
      ? ('משלוח ל' + delivery.cityLabel + (shippingFee === 0 ? ' (חינם)' : ''))
      : 'איסוף עצמי (חינם)';

    var orderPayload = {
      orderNum: orderNum,
      userId: currentUser.uid,
      userEmail: currentUser.email || '',
      customer: { name: name, phone: phone },
      checkout: {
        payment: payment,
        address: deliveryMode === 'delivery' ? addressInput : '',
        readyBy: readyBy,
        note: note,
        deliveryMode: deliveryMode,
        deliveryCity: deliveryMode === 'delivery' ? deliveryCity : '',
        deliveryCityLabel: deliveryMode === 'delivery' ? delivery.cityLabel : '',
        deliveryFee: shippingFee,
        deliveryText: deliveryLabel
      },
      items: cartItems,
      totals: {
        subtotal: subtotal,
        shippingFee: shippingFee,
        autoOrderTotal: autoOrderTotal,
        orderTotal: orderTotal,
        pointsToAdd: pointsToAdd
      },
      rewardRedeemed: reward ? { level: reward.level, name: reward.name, value: reward.value } : null,
      status: 'new',
      source: 'web-cart',
      createdAt: fb.serverTimestamp()
    };

    var sheetsPayload = {
      orderNum: orderNum,
      date: new Date().toLocaleString('he-IL'),
      name: name,
      phone: phone,
      product: 'סל הזמנה',
      description: cartItems.map(function(i){ return i.name; }).join(' | '),
      payment: payment,
      deliveryMode: deliveryMode,
      deliveryCity: deliveryMode === 'delivery' ? delivery.cityLabel : 'איסוף עצמי (חינם)',
      deliveryFee: shippingFee,
      address: deliveryMode === 'delivery' ? addressInput : '',
      readyBy: readyBy,
      notes: note,
      status: 'ממתינה',
      subtotal: subtotal,
      orderTotal: orderTotal,
      pointsAdded: pointsToAdd,
      rewardRedeemed: reward ? (reward.name + ' (רמה ' + reward.level + ')') : ''
    };

    setCheckoutPending(true);
    try {
      await fb.setDoc(fb.doc(fb.db, 'users', currentUser.uid), {
        email: currentUser.email || '',
        updatedAt: fb.serverTimestamp()
      }, { merge: true });

      await fb.addDoc(fb.collection(fb.db, 'orders'), orderPayload);

      var pointsUpdated = true;
      try {
        var userUpdates = {
          email: currentUser.email || '',
          updatedAt: fb.serverTimestamp()
        };

        if(pointsToAdd > 0){
          userUpdates.points = fb.increment(pointsToAdd);
        }

        if(reward){
          userUpdates.redeemedRewards = fb.arrayUnion(reward.level);
        }

        await fb.setDoc(fb.doc(fb.db, 'users', currentUser.uid), userUpdates, { merge: true });
      } catch(pointsErr){
        pointsUpdated = false;
      }

      var sheetsOk = false;
      try {
        if(typeof SHEETS_URL !== 'undefined' && SHEETS_URL && SHEETS_URL !== 'YOUR_GOOGLE_SCRIPT_URL_HERE'){
          await fetch(SHEETS_URL, {
            method: 'POST',
            mode: 'no-cors',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(sheetsPayload)
          });
          sheetsOk = true;
        }
      } catch(sheetErr){
        sheetsOk = false;
      }

      cartItems = [];
      selectedRewardLevel = null;
      manualTotalTouched = false;
      saveCart();
      renderCart();
      await loadProfile();
      renderRewards();
      renderPoints();
      toggleCart(false);

      if(!pointsUpdated){
        toast('ההזמנה נשמרה, אבל עדכון נקודות יתעכב.');
      } else if(!sheetsOk){
        toast('ההזמנה נשמרה במערכת. יש תקלה זמנית בשליחה ל-Google Sheets.');
      } else {
        toast('ההזמנה נשלחה בהצלחה');
      }
    } catch(err){
      toast('שגיאה בשליחת הזמנה למערכת: ' + (err && err.code ? err.code : 'error'));
    } finally {
      setCheckoutPending(false);
    }
  };

  var originalOpenModal = window.openModal;
  if(typeof originalOpenModal === 'function'){
    window.openModal = function(card){
      if(!currentUser){
        toast('צריך להתחבר כדי להזמין ולקבל מתנות');
        openAuthModal();
        return;
      }
      originalOpenModal(card);
      if(window.selProd){
        window.selProd.price = Number((card && card.getAttribute('data-price')) || 0);
      }
      if(document.getElementById('confirmBar')){
        document.getElementById('confirmBar').style.display = 'none';
      }
      if(document.getElementById('submitBtn')){
        document.getElementById('submitBtn').textContent = '🛒 הוספה לסל';
      }
    };
  }

  window.submitOrder = function(){
    if(!currentUser){
      toast('צריך להתחבר כדי להזמין ולקבל מתנות');
      openAuthModal();
      return;
    }

    if(!window.selProd || !window.selProd.name){
      toast('לא נבחר מוצר');
      return;
    }

    var inscription = (document.getElementById('inscriptionInput').value || '').trim();
    var cfColors = (document.getElementById('cfColors').value || '').trim();
    var cfFreeText = (document.getElementById('cfFreeText').value || '').trim();
    var details = [];

    var price = 0;
    if(window.selProd.isCustom){
      if(typeof updateCustomTotal === 'function') updateCustomTotal();
      price = Number(window.customTotal || 0);
      if(price <= 0){
        toast('במארז מותאם צריך לבחור פריטים לפני הוספה לסל');
        return;
      }
      if(window.customSummary) details.push(window.customSummary);
    } else {
      price = Number(window.selProd.price || 0);
      if(price > 0){
        details.push('מחיר מוצר: ' + shekel(price));
      }
    }

    if(inscription) details.push('כיתוב: ' + inscription);
    if(window.selOcc) details.push('מאורע: ' + window.selOcc);
    if(cfColors) details.push('צבעים: ' + cfColors);
    if(cfFreeText) details.push('פירוט: ' + cfFreeText);

    cartItems.push({
      id: 'i_' + Date.now() + '_' + Math.floor(Math.random() * 10000),
      name: window.selProd.name,
      price: price,
      details: details.join(' | ')
    });

    saveCart();
    renderCart();
    if(typeof closeModal === 'function') closeModal();
    toggleCart(true);
    toast('נוסף לסל');
  };

  ensureUI();
  setAuthUI();
  renderCart();
  renderPoints();

  window.addEventListener('firebase-ready', authReady);
})();
</script>
<script>
(function(){
  var ADMIN_ALIAS = 'שרה חברוני';
  var ADMIN_EMAIL = 'admin@sarabakery.local';
  var ADMIN_PASS = '123456';

  var fb = null;
  var adminUiReady = false;
  var isAdmin = false;

  function notify(msg){
    var el = document.getElementById('saraToast');
    if(el){
      el.textContent = msg;
      el.classList.add('show');
      setTimeout(function(){ el.classList.remove('show'); }, 2600);
    } else {
      alert(msg);
    }
  }

  function shekel(n){
    return '₪' + Number(n || 0).toLocaleString('he-IL');
  }

  function ensureAdminUI(){
    if(adminUiReady) return;

    var style = document.createElement('style');
    style.textContent = [
      '.admin-fab{position:fixed;left:14px;top:210px;z-index:900;background:#2d1a0e;color:#fff;border:none;border-radius:999px;width:50px;height:50px;display:none;align-items:center;justify-content:center;font-size:20px;cursor:pointer;box-shadow:0 8px 20px rgba(0,0,0,.3)}',
      '.admin-panel{position:fixed;right:0;top:0;height:100vh;width:min(560px,96vw);background:#fff;z-index:1250;box-shadow:-20px 0 40px rgba(0,0,0,.25);transform:translateX(102%);transition:transform .25s ease;display:flex;flex-direction:column}',
      '.admin-panel.open{transform:translateX(0)}',
      '.admin-head{padding:14px 16px;border-bottom:1px solid #eee;display:flex;align-items:center;justify-content:space-between}',
      '.admin-body{padding:12px 14px;overflow:auto;flex:1;background:#fffaf5}',
      '.admin-note{font-size:12px;color:#7a5040;background:#fff;border:1px solid #f2d9c0;border-radius:10px;padding:8px;margin-bottom:10px}',
      '.admin-card{background:#fff;border:1px solid #f2d9c0;border-radius:12px;padding:10px;margin-bottom:10px}',
      '.admin-row{display:flex;align-items:center;justify-content:space-between;gap:8px}',
      '.admin-mini{font-size:12px;color:#7a5040}',
      '.admin-progress{height:8px;background:#ecd8c9;border-radius:999px;overflow:hidden;margin-top:6px}',
      '.admin-progress > div{height:100%;background:linear-gradient(90deg,#27ae60,#d4a24e)}',
      '.admin-btn{border:none;background:#c8704a;color:#fff;border-radius:8px;padding:6px 10px;cursor:pointer;font-size:12px;font-weight:700}'
    ].join('');
    document.head.appendChild(style);

    document.body.insertAdjacentHTML('beforeend',
      '<button id="adminFab" class="admin-fab" type="button" title="פאנל מנהלת" onclick="toggleAdminPanel(true)">📊</button>' +
      '<div id="adminPanel" class="admin-panel">' +
        '<div class="admin-head"><strong>פאנל מנהלת - שרה</strong><button type="button" class="admin-btn" onclick="toggleAdminPanel(false)">סגירה</button></div>' +
        '<div class="admin-body">' +
          '<div class="admin-note">סיסמאות משתמשים לא ניתנות לצפייה ב‑Firebase (מאובטח). במקום זה אפשר לשלוח איפוס סיסמה למייל.</div>' +
          '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px"><strong>משתמשים</strong><button type="button" class="admin-btn" onclick="refreshAdminData()">רענון</button></div>' +
          '<div id="adminUsersList"></div>' +
          '<div style="display:flex;justify-content:space-between;align-items:center;margin:12px 0 8px"><strong>הזמנות אחרונות</strong></div>' +
          '<div id="adminOrdersList"></div>' +
        '</div>' +
      '</div>'
    );

    adminUiReady = true;
  }

  function setAdminButton(){
    ensureAdminUI();
    var btn = document.getElementById('adminFab');
    if(btn){ btn.style.display = isAdmin ? 'flex' : 'none'; }
    if(!isAdmin){
      var panel = document.getElementById('adminPanel');
      if(panel) panel.classList.remove('open');
    }
  }

  function calcProgress(points){
    var p = Number(points || 0);
    var next = (Math.floor(p / 300) + 1) * 300;
    var prev = next - 300;
    var pct = Math.max(0, Math.min(100, ((p - prev) / 300) * 100));
    return { points: p, next: next, pct: pct };
  }

  async function loadIsAdmin(user){
    if(!fb || !user) return false;
    if(user.email === ADMIN_EMAIL) return true;
    try {
      var s = await fb.getDoc(fb.doc(fb.db, 'users', user.uid));
      if(!s.exists()) return false;
      var d = s.data() || {};
      return d.role === 'admin';
    } catch(e){
      return false;
    }
  }

  async function refreshUsers(){
    if(!isAdmin || !fb) return;
    var wrap = document.getElementById('adminUsersList');
    if(!wrap) return;

    try {
      var snap = await fb.getDocs(fb.collection(fb.db, 'users'));
      var users = [];
      snap.forEach(function(docSnap){
        var d = docSnap.data() || {};
        users.push({ id: docSnap.id, email: d.email || '', points: Number(d.points || 0), role: d.role || '', redeemedRewards: d.redeemedRewards || [] });
      });

      users.sort(function(a,b){ return b.points - a.points; });

      if(users.length === 0){
        wrap.innerHTML = '<div class="admin-mini">אין משתמשים עדיין.</div>';
        return;
      }

      var html = '';
      users.forEach(function(u){
        var pr = calcProgress(u.points);
        var rewardCount = Math.floor(u.points / 300);
        html += '<div class="admin-card">' +
          '<div class="admin-row"><strong>' + (u.email || 'ללא אימייל') + '</strong><span class="admin-mini">' + (u.role || 'user') + '</span></div>' +
          '<div class="admin-mini">נקודות: ' + u.points + ' | יעד הבא: ' + pr.next + ' | מתנות פתוחות: ' + rewardCount + '</div>' +
          '<div class="admin-progress"><div style="width:' + pr.pct + '%"></div></div>' +
          '<div style="margin-top:8px;display:flex;gap:8px;justify-content:flex-end">' +
            (u.email ? ('<button class="admin-btn" type="button" onclick="adminResetPassword(\'' + u.email + '\')">איפוס סיסמה</button>') : '') +
          '</div>' +
        '</div>';
      });

      wrap.innerHTML = html;
    } catch(err){
      wrap.innerHTML = '<div class="admin-mini">שגיאה בטעינת משתמשים.</div>';
    }
  }

  function formatDate(ts){
    if(!ts) return 'לא ידוע';
    try {
      if(ts.seconds){ return new Date(ts.seconds * 1000).toLocaleString('he-IL'); }
      return new Date(ts).toLocaleString('he-IL');
    } catch(e){
      return 'לא ידוע';
    }
  }

  function normalizeWaNumber(phone){
    var digits = String(phone || '').replace(/\D/g, '');
    if(!digits) return '';
    if(digits.indexOf('972') === 0) return digits;
    if(digits.charAt(0) === '0') return '972' + digits.slice(1);
    return digits;
  }

  function cityLabelByCode(code){
    if(code === 'harish') return 'חריש';
    if(code === 'tal_menashe') return 'טל מנשה';
    if(code === 'pardes_hanna') return 'פרדס חנה';
    return code || '';
  }

  function buildReadyOrderWhatsApp(orderId, customer, checkout, totals){
    var wa = normalizeWaNumber(customer && customer.phone ? customer.phone : '');
    if(!wa) return '';

    var orderNum = orderId || '';
    var deliveryMode = checkout && checkout.deliveryMode ? checkout.deliveryMode : (checkout && checkout.address ? 'delivery' : 'pickup');
    var cityLabel = checkout && checkout.deliveryCityLabel ? checkout.deliveryCityLabel : cityLabelByCode(checkout && checkout.deliveryCity ? checkout.deliveryCity : '');
    var deliveryFee = Number((checkout && checkout.deliveryFee) || (totals && totals.shippingFee) || 0);
    var orderTotal = Number((totals && totals.orderTotal) || (totals && totals.autoOrderTotal) || 0);

    var lines = [];
    lines.push('היי ' + (customer && customer.name ? customer.name : '') + ', ההזמנה #' + orderNum + ' מוכנה 🎉');

    if(deliveryMode === 'delivery'){
      lines.push('משלוח: ' + (cityLabel || 'יעד משלוח') + ' | דמי משלוח ' + shekel(deliveryFee));
      if(checkout && checkout.address){
        lines.push('כתובת: ' + checkout.address);
      }
    } else {
      lines.push('איסוף עצמי מוכן - אפשר להגיע לאסוף 🎁');
      lines.push('כתובת איסוף: ' + PICKUP_ADDRESS);
    }

    if(orderTotal > 0){
      lines.push('סכום לתשלום: ' + shekel(orderTotal));
    }

    lines.push('שרה חברוני');
    return 'https://wa.me/' + wa + '?text=' + encodeURIComponent(lines.join('\n'));
  }

  async function refreshOrders(){
    if(!isAdmin || !fb) return;
    var wrap = document.getElementById('adminOrdersList');
    if(!wrap) return;

    try {
      var snap = await fb.getDocs(fb.collection(fb.db, 'orders'));
      var orders = [];
      snap.forEach(function(docSnap){
        var d = docSnap.data() || {};
        orders.push({ id: docSnap.id, data: d });
      });

      orders.sort(function(a,b){
        var at = a.data && a.data.createdAt && a.data.createdAt.seconds ? a.data.createdAt.seconds : 0;
        var bt = b.data && b.data.createdAt && b.data.createdAt.seconds ? b.data.createdAt.seconds : 0;
        return bt - at;
      });

      if(orders.length === 0){
        wrap.innerHTML = '<div class="admin-mini">אין הזמנות עדיין.</div>';
        return;
      }

      var html = '';
      orders.slice(0, 100).forEach(function(o){
        var d = o.data || {};
        var customer = d.customer || {};
        var checkout = d.checkout || {};
        var totals = d.totals || {};
        var orderNum = d.orderNum || o.id;
        var reward = d.rewardRedeemed ? (d.rewardRedeemed.name + ' (רמת ' + d.rewardRedeemed.level + ')') : 'ללא מימוש מתנה';
        var itemsText = Array.isArray(d.items) ? d.items.map(function(i){ return i.name; }).join(' | ') : '';
        var deliveryMode = checkout.deliveryMode || (checkout.address ? 'delivery' : 'pickup');
        var deliveryCityLabel = checkout.deliveryCityLabel || cityLabelByCode(checkout.deliveryCity || '');
        var deliveryFee = Number(checkout.deliveryFee || totals.shippingFee || 0);
        var deliveryText = deliveryMode === 'delivery'
          ? ('משלוח ל' + (deliveryCityLabel || 'יעד לא נבחר') + ' | דמי משלוח: ' + shekel(deliveryFee))
      : 'איסוף עצמי (חינם)';
        var addressText = deliveryMode === 'delivery' ? (checkout.address || 'לא הוזנה') : (PICKUP_ADDRESS + ' (איסוף עצמי)');
        var waReady = buildReadyOrderWhatsApp(orderNum, customer, checkout, totals);

        html += '<div class="admin-card">' +
          '<div class="admin-row"><strong>' + (customer.name || 'ללא שם') + '</strong><span class="admin-mini">' + formatDate(d.createdAt) + '</span></div>' +
          '<div class="admin-mini">מספר הזמנה: ' + orderNum + '</div>' +
          '<div class="admin-mini">מייל משתמש: ' + (d.userEmail || 'לא ידוע') + '</div>' +
          '<div class="admin-mini">טלפון: ' + (customer.phone || 'לא ידוע') + '</div>' +
          '<div class="admin-mini">כתובת: ' + addressText + '</div>' +
          '<div class="admin-mini">משלוח: ' + deliveryText + '</div>' +
          '<div class="admin-mini">תשלום: ' + (checkout.payment || 'לא צוין') + ' | סכום: ' + shekel(totals.orderTotal || totals.autoOrderTotal || 0) + ' | נקודות שנוספו: ' + (totals.pointsToAdd || 0) + '</div>' +
          '<div class="admin-mini">מתנה: ' + reward + '</div>' +
          '<div class="admin-mini">פריטים: ' + (itemsText || 'ללא פריטים (מימוש בלבד)') + '</div>' +
          '<div style="margin-top:8px;display:flex;justify-content:flex-end">' +
            (waReady ? ('<a class="admin-btn" href="' + waReady + '" target="_blank" rel="noopener" style="text-decoration:none">וואטסאפ: הזמנה מוכנה</a>') : '') +
          '</div>' +
        '</div>';
      });

      wrap.innerHTML = html;
    } catch(err){
      wrap.innerHTML = '<div class="admin-mini">שגיאה בטעינת הזמנות.</div>';
    }
  }

  async function refreshAdminData(){
    await refreshUsers();
    await refreshOrders();
  }

  window.refreshAdminData = refreshAdminData;

  window.toggleAdminPanel = async function(open){
    ensureAdminUI();
    if(!isAdmin){
      notify('גישה למנהלת בלבד');
      return;
    }
    var panel = document.getElementById('adminPanel');
    if(!panel) return;
    if(open){
      panel.classList.add('open');
      await refreshAdminData();
    } else {
      panel.classList.remove('open');
    }
  };

  window.adminResetPassword = async function(email){
    if(!isAdmin || !fb) return;
    try {
      await fb.sendPasswordResetEmail(fb.auth, email);
      notify('נשלח מייל לאיפוס סיסמה ל: ' + email);
    } catch(err){
      notify('שגיאה בשליחת איפוס סיסמה');
    }
  };

  function overrideLogin(){
    var original = window.loginUser;
    if(typeof original !== 'function' || original.__adminWrapped) return;

    var wrapped = async function(){
      ensureAdminUI();
      if(!fb){
        notify('Firebase לא מוכן');
        return;
      }

      var emailEl = document.getElementById('authEmail');
      var passEl = document.getElementById('authPass');
      var inputUser = (emailEl && emailEl.value ? emailEl.value : '').trim();
      var pass = (passEl && passEl.value ? passEl.value : '').trim();

      if(inputUser === ADMIN_ALIAS){
        if(pass !== ADMIN_PASS){
          notify('סיסמת מנהלת לא נכונה');
          return;
        }

        try {
          try {
            await fb.signInWithEmailAndPassword(fb.auth, ADMIN_EMAIL, ADMIN_PASS);
          } catch(err){
            if(err && (err.code === 'auth/user-not-found' || err.code === 'auth/invalid-credential' || err.code === 'auth/invalid-email')){
              var cred = await fb.createUserWithEmailAndPassword(fb.auth, ADMIN_EMAIL, ADMIN_PASS);
              if(cred && cred.user){
                await fb.setDoc(fb.doc(fb.db, 'users', cred.user.uid), {
                  email: ADMIN_EMAIL,
                  role: 'admin',
                  points: 0,
                  redeemedRewards: [],
                  createdAt: fb.serverTimestamp(),
                  updatedAt: fb.serverTimestamp()
                }, { merge: true });
              }
            } else {
              throw err;
            }
          }

          if(typeof window.closeAuthModal === 'function') window.closeAuthModal();
          notify('כניסה כמנהלת בוצעה');
          return;
        } catch(e){
          notify('שגיאה בכניסת מנהלת');
          return;
        }
      }

      return original();
    };

    wrapped.__adminWrapped = true;
    window.loginUser = wrapped;
  }

  async function initAdminAddon(){
    ensureAdminUI();

    if(!window.firebaseCtx){
      window.addEventListener('firebase-ready', initAdminAddon, { once: true });
      return;
    }

    fb = window.firebaseCtx;
    overrideLogin();

    fb.onAuthStateChanged(fb.auth, async function(user){
      isAdmin = await loadIsAdmin(user);
      setAdminButton();
    });
  }

  initAdminAddon();
})();
</script>
</body>
</html>



































