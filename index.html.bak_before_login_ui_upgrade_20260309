<script>
    var selProd={name:'',img:'',descFull:'',isCustom:false}, selPay='', selOcc='', wantsDelivery=false, customTotal=0, customSummary='';

    function shekel(n){
        return '₪' + Number(n||0).toLocaleString('he-IL');
    }

    function resetCustomBuilder(){
        customTotal=0;
        customSummary='';
        document.querySelectorAll('#customBuilderStep .builder-qty').forEach(function(inp){
            inp.value='0';
        });
        var totalEl=document.getElementById('customTotal');
        if(totalEl) totalEl.textContent='סה"כ משוער: ' + shekel(0);
        var noteEl=document.getElementById('customBuilderNote');
        if(noteEl) noteEl.style.display='none';
    }

    function updateCustomTotal(){
        var total=0;
        var rows=[];
        document.querySelectorAll('#customBuilderStep .builder-qty').forEach(function(inp){
            var qty=Math.max(0, parseInt(inp.value||'0',10)||0);
            inp.value=String(qty);
            if(qty>0){
                var price=parseInt(inp.getAttribute('data-price')||'0',10)||0;
                var item=inp.getAttribute('data-item')||'';
                var rowTotal=qty*price;
                total+=rowTotal;
                rows.push(item+' x'+qty+' = '+shekel(rowTotal));
            }
        });
        customTotal=total;
        customSummary=rows.join(' | ');
        var totalEl=document.getElementById('customTotal');
        if(totalEl) totalEl.textContent='סה"כ משוער: ' + shekel(total);
        return total;
    }

    function goToOrderDetails(){
        var total=updateCustomTotal();
        var noteEl=document.getElementById('customBuilderNote');
        if(total<=0){
            if(noteEl) noteEl.style.display='block';
            return;
        }
        if(noteEl) noteEl.style.display='none';
        document.getElementById('customBuilderStep').style.display='none';
        document.getElementById('orderDetailsStep').style.display='block';
        document.getElementById('backToBuilderBtn').style.display='block';
    }

    function backToBuilder(){
        document.getElementById('orderDetailsStep').style.display='none';
        document.getElementById('customBuilderStep').style.display='block';
    }

    function filterCat(cat,el){
        document.querySelectorAll('.cat-tab').forEach(t=>t.classList.remove('active'));
        el.classList.add('active');
        document.querySelectorAll('.prod-card').forEach(p=>{
            p.style.display=(cat==='all'||p.dataset.cat===cat)?'block':'none';
        });
    }

    function toggleDelivery(){
        wantsDelivery=!wantsDelivery;
        var tog=document.getElementById('deliveryToggle');
        var wrap=document.getElementById('deliveryAddressWrap');
        if(wantsDelivery){tog.classList.add('on');wrap.style.display='block';}
        else{tog.classList.remove('on');wrap.style.display='none';}
    }

    function openModal(card){
        var imgEl=card.querySelector('.prod-img img');
        var img=imgEl?imgEl.src:'';
        var name=card.querySelector('.prod-name').textContent;
        var desc=card.querySelector('.prod-desc').textContent;
        var descFull=card.dataset.descFull||desc;
        var isCustom=card.dataset.cat==='custom';

        var mImg=document.getElementById('mImg');
        mImg.src=img;
        mImg.style.display=img?'block':'none';

        document.getElementById('mTitle').textContent=name;
        document.getElementById('mDesc').textContent=desc;
        document.getElementById('nameInput').value='';
        document.getElementById('phoneInput').value='';
        document.getElementById('noteInput').value='';
        document.getElementById('inscriptionInput').value='';
        document.getElementById('deliveryDate').value='';
        document.getElementById('deliveryAddress').value='';
        document.getElementById('cfColors').value='';
        document.getElementById('cfFreeText').value='';
        document.getElementById('modalForm').style.display='block';
        document.getElementById('modalSuccess').style.display='none';
        document.getElementById('confirmBar').style.display='none';
        document.getElementById('submitBtn').style.display='flex';
        document.querySelectorAll('.pay-opt').forEach(p=>p.classList.remove('selected'));
        document.querySelectorAll('.occ-chip').forEach(c=>c.classList.remove('selected'));

        // reset delivery
        wantsDelivery=false;
        document.getElementById('deliveryToggle').classList.remove('on');
        document.getElementById('deliveryAddressWrap').style.display='none';

        document.getElementById('customFields').style.display=isCustom?'block':'none';
        document.getElementById('inscriptionArea').style.display='block';
        document.getElementById('backToBuilderBtn').style.display='none';
        document.getElementById('orderDetailsStep').style.display='block';
        document.getElementById('customBuilderStep').style.display='none';

        var ph=document.getElementById('mImgPlaceholder');
        if(isCustom){ph.style.display='flex';mImg.style.display='none';}
        else{ph.style.display='none';}

        if(isCustom){
            resetCustomBuilder();
            document.getElementById('orderDetailsStep').style.display='none';
            document.getElementById('customBuilderStep').style.display='block';
            document.getElementById('mDesc').textContent='בחרו פריטים וכמויות לפי התפריט, ואז המשיכו לפרטי ההזמנה.';
        }

        selPay=''; selOcc=''; customTotal=0; customSummary='';
        selProd={name,img,descFull,isCustom};
        document.getElementById('modalOverlay').classList.add('open');
        document.body.style.overflow='hidden';
    }

    function closeModal(){
        document.getElementById('modalOverlay').classList.remove('open');
        document.body.style.overflow='';
    }

    function closeModalOut(e){if(e.target===document.getElementById('modalOverlay'))closeModal();}

    function selectPay(el,val){
        document.querySelectorAll('.pay-opt').forEach(p=>p.classList.remove('selected'));
        el.classList.add('selected'); selPay=val;
    }

    function selectOcc(el,val){
        document.querySelectorAll('.occ-chip').forEach(c=>c.classList.remove('selected'));
        el.classList.add('selected'); selOcc=val;
    }

    function submitOrder(){
        var name=document.getElementById('nameInput').value.trim();
        var phone=document.getElementById('phoneInput').value.trim();
        if(!name){
            document.getElementById('nameInput').style.borderColor='#e74c3c';
            document.getElementById('nameInput').focus();
            return;
        }
        document.getElementById('nameInput').style.borderColor='';
        if(!phone||phone.length<9){
            document.getElementById('phoneInput').style.borderColor='#e74c3c';
            document.getElementById('phoneInput').focus();
            return;
        }
        document.getElementById('phoneInput').style.borderColor='';

        var inscription=document.getElementById('inscriptionInput').value.trim();
        var deliveryDate=document.getElementById('deliveryDate').value.trim();
        var deliveryAddress=document.getElementById('deliveryAddress').value.trim();
        var cfColors=document.getElementById('cfColors').value.trim();
        var cfFreeText=document.getElementById('cfFreeText').value.trim();

        if(selProd.isCustom){
            updateCustomTotal();
        }

        var summary='שם: '+name+'\n';
        summary+='טלפון: '+phone+'\n';
        summary+='מוצר: '+selProd.name+'\n';
        if(selProd.isCustom){
            if(customSummary) summary+='בחירת פריטים: '+customSummary+'\n';
            summary+='סה"כ משוער: '+shekel(customTotal)+'\n';
        }
        if(inscription) summary+='כיתוב: '+inscription+'\n';
        if(selOcc) summary+='מאורע: '+selOcc+'\n';
        if(cfColors) summary+='צבעים: '+cfColors+'\n';
        if(cfFreeText) summary+='פירוט: '+cfFreeText+'\n';
        summary+='משלוח: '+(wantsDelivery?'כן +₪10':'לא - איסוף עצמי')+'\n';
        if(wantsDelivery&&deliveryAddress) summary+='כתובת: '+deliveryAddress+'\n';
        if(deliveryDate) summary+='מוכן עד: '+deliveryDate+'\n';
        if(selPay) summary+='תשלום: '+selPay;

        document.getElementById('confirmSummary').textContent=summary;
        document.getElementById('confirmBar').style.display='block';
        document.getElementById('submitBtn').style.display='none';
        document.getElementById('confirmBar').scrollIntoView({behavior:'smooth',block:'nearest'});
    }

    function cancelConfirm(){
        document.getElementById('confirmBar').style.display='none';
        document.getElementById('submitBtn').style.display='flex';
    }

