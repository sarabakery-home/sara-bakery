  function renderPoints(){
    ensureUI();
    var el = document.getElementById('pointsWrap');
    if(!el) return;

    if(!currentUser){
      el.innerHTML = '<div style=\"font-size:12px;color:#7a5040;line-height:1.6\">ЧңЧҗ ЧһЧ—Ч•Ч‘ЧЁЧҷЧқ ЧўЧ“ЧҷЧҷЧҹ. Ч”ЧӘЧ—Ч‘ЧЁЧ• ЧӣЧ“Чҷ ЧңЧҰЧ‘Ч•ЧЁ Ч Ч§Ч•Ч“Ч•ЧӘ Ч•ЧңЧӨЧӘЧ•Ч— ЧһЧӘЧ Ч•ЧӘ.</div>';
      return;
    }

    var points = Number(profile.points || 0);
    var milestones = [300, 600, 900];
    var maxShown = milestones[milestones.length - 1];
    var meterPct = Math.max(0, Math.min(100, (points / maxShown) * 100));
    var nextLevel = (Math.floor(points / 300) + 1) * 300;
    var missing = Math.max(0, nextLevel - points);

    var marksHtml = milestones.map(function(level){
      var gift = getGiftForLevel(level);
      var hit = points >= level;
      var pos = (level / maxShown) * 100;
      return '<div class=\"points-mark ' + (hit ? 'hit' : '') + '\" style=\"left:' + pos + '%\">' +
        '<span class=\"points-emoji\">' + escapeHtml(gift.emoji) + '</span>' +
        '<span class=\"points-dot\"></span>' +
      '</div>';
    }).join('');

    var chipsHtml = milestones.map(function(level){
      var gift = getGiftForLevel(level);
      var hit = points >= level;
      return '<div class=\"points-chip ' + (hit ? 'hit' : '') + '\">' +
        '<strong>' + escapeHtml(gift.emoji) + ' ' + level + '</strong>' +
        '<div class=\"pc-sub\">' + escapeHtml(gift.name) + '</div>' +
      '</div>';
    }).join('');

    var nextText = points >= maxShown
      ? 'ЧӨЧӘЧ—ЧӘЧқ ЧӣЧ‘ЧЁ ЧҗЧӘ 300/600/900. ЧһЧһЧ©ЧҷЧӣЧҷЧқ ЧңЧҰЧ‘Ч•ЧЁ Чң-' + nextLevel + ' Ч Ч§Чі'
      : 'ЧўЧ“ Ч”ЧһЧӘЧ Ч” Ч”Ч‘ЧҗЧ”: ' + missing + ' Ч Ч§Чі';

    el.innerHTML =
      '<div class=\"points-head\"><div class=\"points-title\">ЧһЧ“ ЧһЧӘЧ Ч•ЧӘ</div><div class=\"points-total\">' + points + ' Ч Ч§Чі</div></div>' +
      '<div class=\"points-meter\"><div class=\"points-line\"><div class=\"points-line-fill\" style=\"width:' + meterPct + '%\"></div></div><div class=\"points-marks\">' + marksHtml + '</div></div>' +
      '<div class=\"points-labels\">' + chipsHtml + '</div>' +
      '<div class=\"points-next\">' + nextText + '</div>';
  }

  function renderRewards(){
    ensureUI();
    var wrap = document.getElementById('rewardList');
    if(!wrap) return;

    if(!currentUser){
      wrap.innerHTML = '';
      return;
    }

    var points = Number(profile.points || 0);
    var redeemed = Array.isArray(profile.redeemedRewards) ? profile.redeemedRewards : [];
    var maxLevel = Math.floor(points / 300) * 300;
    var levels = [];
    for(var lvl=300; lvl<=maxLevel; lvl+=300){
      if(redeemed.indexOf(lvl) === -1){
        levels.push(lvl);
      }
    }

    if(levels.length === 0){
      wrap.innerHTML = '<div style="font-size:12px;color:#7a5040;margin-bottom:10px">ЧҗЧҷЧҹ ЧӣЧЁЧ’Чў ЧһЧӘЧ Ч” ЧӨЧӘЧ•Ч—Ч” ЧңЧһЧҷЧһЧ•Ч©.</div>';
      selectedRewardLevel = null;
      return;
    }

    var html = '<div style="font-weight:800;margin:8px 0">ЧһЧӘЧ Ч•ЧӘ Ч–ЧһЧҷЧ Ч•ЧӘ ЧңЧһЧҷЧһЧ•Ч©</div>';
    levels.forEach(function(level){
      var gift = getGiftForLevel(level);
      var picked = selectedRewardLevel === level;
      html += '<div class="reward-chip">' +
        '<div><strong>' + gift.emoji + ' ' + gift.name + '</strong><div style="font-size:12px;color:#7a5040">ЧЁЧһЧӘ ' + level + ' Ч Ч§Чі | Ч©Ч•Ч•Чҷ ' + shekel(gift.value) + '</div></div>' +
        '<button type="button" onclick="selectReward(' + level + ')" style="background:' + (picked ? '#27ae60' : '#c8704a') + '">' + (picked ? 'Ч Ч‘Ч—ЧЁ' : 'ЧһЧһЧ©') + '</button>' +
      '</div>';
    });

    wrap.innerHTML = html;
  }

  function escapeHtml(v){
    return String(v || '').replace(/[&<>"]|'/g, function(ch){
      var map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', '\'': '&#39;' };
      return map[ch] || ch;
    });
  }

  function starsByRate(rate){
    var r = Math.max(1, Math.min(5, Number(rate || 5)));
    return 'вҳ…вҳ…вҳ…вҳ…вҳ…'.slice(0, r) + 'вҳҶвҳҶвҳҶвҳҶвҳҶ'.slice(0, 5 - r);
  }

  function formatReviewDate(ts){
    if(!ts) return '';
    try {
      if(ts.seconds){ return new Date(ts.seconds * 1000).toLocaleDateString('he-IL'); }
      return new Date(ts).toLocaleDateString('he-IL');
    } catch(e){
      return '';
    }
  }

  function renderUserReviewCard(r){
    var name = escapeHtml(r.name || 'ЧңЧ§Ч•Ч—Ч”');
    var city = escapeHtml(r.city || 'ЧңЧҗ ЧҰЧ•ЧҷЧҹ');
    var text = escapeHtml(r.text || '');
    var stars = starsByRate(r.rating || 5);
    var initial = name ? name.charAt(0) : 'Чң';
    var dateTxt = formatReviewDate(r.createdAt);
    var media = '';

    if(Array.isArray(r.images) && r.images.length){
      media = '<div class="review-media">';
      r.images.forEach(function(url){
        media += '<img src="' + escapeHtml(url) + '" alt="ЧӘЧһЧ•Ч ЧӘ Ч‘ЧҷЧ§Ч•ЧЁЧӘ" loading="lazy">';
      });
      media += '</div>';
    }

    return '<div class="review-card">' +
      '<div class="rc-top"><div class="rc-author"><div class="rc-av">' + escapeHtml(initial) + '</div><div><div class="rc-name">' + name + '</div><div class="rc-loc">' + city + (dateTxt ? ' В· ' + escapeHtml(dateTxt) : '') + '</div></div></div><div class="rc-stars">' + stars + '</div></div>' +
      '<div class="rc-text">"' + text + '"</div>' +
      media +
    '</div>';
  }

  function renderUserReviews(){
    var wrap = document.getElementById('reviewsUserList');
    if(!wrap) return;

    if(!userReviews || userReviews.length === 0){
      wrap.innerHTML = '';
      return;
