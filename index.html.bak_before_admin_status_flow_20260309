    function resetCustomBuilder(){
        customTotal=0;
        customSummary='';
        document.querySelectorAll('#customBuilderStep .builder-qty').forEach(function(inp){
            inp.value='0';
        });
        var totalEl=document.getElementById('customTotal');
        if(totalEl) totalEl.textContent='ЧЎЧ”"Чӣ ЧһЧ©Ч•ЧўЧЁ: ' + shekel(0);
        var noteEl=document.getElementById('customBuilderNote');
        if(noteEl) noteEl.style.display='none';
    }

    function updateCustomTotal(){
        var total=0;
        var rows=[];
        document.querySelectorAll('#customBuilderStep .builder-qty').forEach(function(inp){
            var qty=Math.max(0, parseInt(inp.value||'0',10)||0);
            inp.value=String(qty);
            if(qty>0){
                var price=parseInt(inp.getAttribute('data-price')||'0',10)||0;
                var item=inp.getAttribute('data-item')||'';
                var rowTotal=qty*price;
                total+=rowTotal;
                rows.push(item+' x'+qty+' = '+shekel(rowTotal));
            }
        });
        customTotal=total;
        customSummary=rows.join(' | ');
        var totalEl=document.getElementById('customTotal');
        if(totalEl) totalEl.textContent='ЧЎЧ”"Чӣ ЧһЧ©Ч•ЧўЧЁ: ' + shekel(total);
        return total;
    }

