      toast('Ч©Ч’ЧҷЧҗЧ” Ч‘Ч©ЧңЧҷЧ—ЧӘ Ч”Ч–ЧһЧ Ч” ЧңЧһЧўЧЁЧӣЧӘ: ' + (err && err.code ? err.code : 'error'));
    } finally {
      setCheckoutPending(false);
    }
  };

  var originalOpenModal = window.openModal;
  if(typeof originalOpenModal === 'function'){
    window.openModal = function(card){
      if(!currentUser){
        nudgeAuth('ЧҰЧЁЧҷЧҡ ЧңЧ”ЧӘЧ—Ч‘ЧЁ ЧӣЧ“Чҷ ЧңЧ”Ч–ЧһЧҷЧҹ Ч•ЧңЧ§Ч‘Чң ЧһЧӘЧ Ч•ЧӘ');
