    if(inscription) details.push('ЧӣЧҷЧӘЧ•Ч‘: ' + inscription);
    if(window.selOcc) details.push('ЧһЧҗЧ•ЧЁЧў: ' + window.selOcc);
    if(cfColors) details.push('ЧҰЧ‘ЧўЧҷЧқ: ' + cfColors);
    if(cfFreeText) details.push('ЧӨЧҷЧЁЧ•Чҳ: ' + cfFreeText);

    cartItems.push({
      id: 'i_' + Date.now() + '_' + Math.floor(Math.random() * 10000),
      name: window.selProd.name,
      price: price,
      details: details.join(' | ')
    });

    saveCart();
    renderCart();
    if(typeof closeModal === 'function') closeModal();
    toggleCart(true);
    toast('Ч Ч•ЧЎЧЈ ЧңЧЎЧң');
