        '<div class="admin-head"><strong>ЧӨЧҗЧ Чң ЧһЧ Ч”ЧңЧӘ - Ч©ЧЁЧ”</strong><button type="button" class="admin-btn" onclick="toggleAdminPanel(false)">ЧЎЧ’ЧҷЧЁЧ”</button></div>' +
        '<div class="admin-body">' +
          '<div class="admin-note">ЧЎЧҷЧЎЧһЧҗЧ•ЧӘ ЧһЧ©ЧӘЧһЧ©ЧҷЧқ ЧңЧҗ Ч ЧҷЧӘЧ Ч•ЧӘ ЧңЧҰЧӨЧҷЧҷЧ” Ч‘вҖ‘Firebase (ЧһЧҗЧ•Ч‘ЧҳЧ—). Ч‘ЧһЧ§Ч•Чқ Ч–Ч” ЧҗЧӨЧ©ЧЁ ЧңЧ©ЧңЧ•Ч— ЧҗЧҷЧӨЧ•ЧЎ ЧЎЧҷЧЎЧһЧ” ЧңЧһЧҷЧҷЧң.</div>' +
          '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px"><strong>ЧһЧ©ЧӘЧһЧ©ЧҷЧқ</strong><button type="button" class="admin-btn" onclick="refreshAdminData()">ЧЁЧўЧ Ч•Чҹ</button></div>' +
          '<div id="adminUsersList"></div>' +
          '<div style="display:flex;justify-content:space-between;align-items:center;margin:12px 0 8px"><strong>Ч”Ч–ЧһЧ Ч•ЧӘ ЧҗЧ—ЧЁЧ•Ч Ч•ЧӘ</strong></div>' +
          '<div id="adminOrdersList"></div>' +
        '</div>' +
